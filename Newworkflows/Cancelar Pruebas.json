    {
      "parameters": {
        "jsCode": "// Obtener el título/nombre de la reserva desde el nodo trigger de este flujo\nconst tituloBuscado = $('Cancelar Evento Esturion').first().json['Titulo'];\n\n// Obtener todos los eventos del Google Calendar (nodo \"Consigue muchos eventos\")\nconst eventos = $input.all();\n\n// Buscar el evento que coincida por título (summary)\nconst eventoEncontrado = eventos.find(evento => \n  evento.json.summary === tituloBuscado\n);\n\n// Si no se encuentra\nif (!eventoEncontrado) {\n  return [{\n    json: {\n      error: 'No se encontró el evento para cancelar',\n      titulo_buscado: tituloBuscado,\n      eventos_encontrados: eventos.length\n    }\n  }];\n}\n\n// Devolver solo el ID real para que el nodo \"Eliminar un evento\" pueda borrarlo\nreturn [{\n  json: {\n    ID_real: eventoEncontrado.json.id,\n    Titulo: eventoEncontrado.json.summary,\n    Fecha_inicio: eventoEncontrado.json.start?.dateTime,\n    Fecha_fin: eventoEncontrado.json.end?.dateTime,\n    Descripcion: eventoEncontrado.json.description\n  }\n}];"
      },
